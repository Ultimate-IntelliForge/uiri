# ─── Database ───────────────────────────────────────────────────────────────
# Supabase pooler (PgBouncer) — used at runtime
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection — used by Prisma migrations only
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── JWT & Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET="replace-with-64-byte-hex-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# Generate with: openssl rand -hex 32
CSRF_SECRET="replace-with-32-byte-hex-secret"

# ─── Google Drive ────────────────────────────────────────────────────────────
# Path to the service account JSON key file (relative to apps/api/)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH="./secrets/google-service-account.json"
# ID of the shared Drive folder for uploads
GOOGLE_DRIVE_FOLDER_ID="your-google-drive-folder-id"

# ─── ISR Revalidation ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
REVALIDATION_SECRET="replace-with-revalidation-secret"
WEB_BASE_URL="http://localhost:3000"

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
